{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kaveep.dev/schemas/knowledge.schema.json",
  "title": "KAVEEP Knowledge",
  "description": "Canonical schema for governed knowledge records within the KAVEEP ecosystem.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "knowledgeId",
    "title",
    "version",
    "category",
    "status",
    "verificationStatus",
    "verificationLevel",
    "kcpSessionId",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "knowledgeId": {
      "type": "string",
      "pattern": "^knowledge_[a-zA-Z0-9_-]+$",
      "description": "Stable unique identifier for the knowledge record."
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "description": "Knowledge version. Breaking meaning changes require a major version increment."
    },
    "category": {
      "type": "string",
      "enum": [
        "verified_knowledge",
        "pending_knowledge",
        "unverified_knowledge",
        "historical_knowledge",
        "deprecated_knowledge",
        "experimental_knowledge",
        "rejected_knowledge",
        "archived_knowledge"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "proposed",
        "collected",
        "organized",
        "evidence_attached",
        "kcp_review",
        "verified",
        "published",
        "updated",
        "deprecated",
        "rejected",
        "archived"
      ]
    },
    "verificationStatus": {
      "type": "string",
      "enum": [
        "verified",
        "unverified",
        "rejected",
        "deprecated",
        "superseded"
      ],
      "description": "KCP verification result. Insufficient evidence must result in unverified."
    },
    "verificationLevel": {
      "type": "string",
      "enum": [
        "unverified",
        "preliminary",
        "reviewed",
        "verified",
        "certified",
        "foundational"
      ],
      "description": "Verification maturity level."
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "summary": {
      "type": "string"
    },
    "contentRef": {
      "type": "string",
      "description": "Reference to the full knowledge content. Large content should not be embedded directly."
    },
    "evidenceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^evidence_[a-zA-Z0-9_-]+$"
      },
      "uniqueItems": true
    },
    "kcpSessionId": {
      "type": "string",
      "pattern": "^kcp_[a-zA-Z0-9_-]+$",
      "description": "KCP session responsible for verification. Knowledge must not bypass KCP."
    },
    "citation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "preferredCitation": {
          "type": "string"
        },
        "sourceRefs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "citationStyle": {
          "type": "string"
        }
      }
    },
    "lineage": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "origin": {
          "type": "string"
        },
        "parentKnowledgeIds": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^knowledge_[a-zA-Z0-9_-]+$"
          },
          "uniqueItems": true
        },
        "derivedKnowledgeIds": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^knowledge_[a-zA-Z0-9_-]+$"
          },
          "uniqueItems": true
        },
        "supersedesKnowledgeId": {
          "type": "string",
          "pattern": "^knowledge_[a-zA-Z0-9_-]+$"
        },
        "supersededByKnowledgeId": {
          "type": "string",
          "pattern": "^knowledge_[a-zA-Z0-9_-]+$"
        }
      }
    },
    "relationships": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "relationshipType",
          "targetKnowledgeId"
        ],
        "properties": {
          "relationshipType": {
            "type": "string",
            "enum": [
              "supports",
              "contradicts",
              "depends_on",
              "extends",
              "replaces",
              "references",
              "related_to"
            ]
          },
          "targetKnowledgeId": {
            "type": "string",
            "pattern": "^knowledge_[a-zA-Z0-9_-]+$"
          },
          "description": {
            "type": "string"
          }
        }
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "domains": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "requiredPolicies": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^policy_[a-zA-Z0-9_-]+$"
      },
      "uniqueItems": true
    },
    "usedByAgentIds": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^agent_[a-zA-Z0-9_-]+$"
      },
      "uniqueItems": true
    },
    "maintenance": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "maintenanceStatus": {
          "type": "string",
          "enum": [
            "current",
            "review_required",
            "outdated",
            "deprecated",
            "archived"
          ]
        },
        "reviewFrequency": {
          "type": "string"
        },
        "lastReviewedAt": {
          "type": "string",
          "format": "date-time"
        },
        "nextReviewAt": {
          "type": "string",
          "format": "date-time"
        },
        "reviewOwner": {
          "type": "string"
        }
      }
    },
    "auditRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^audit_[a-zA-Z0-9_-]+$"
      },
      "uniqueItems": true
    },
    "eventRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^event_[a-zA-Z0-9_-]+$"
      },
      "uniqueItems": true
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    },
    "createdBy": {
      "type": "string"
    },
    "updatedBy": {
      "type": "string"
    },
    "publishedAt": {
      "type": "string",
      "format": "date-time"
    },
    "deprecatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
