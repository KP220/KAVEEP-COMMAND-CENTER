{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kaveep.dev/schemas/audit.schema.json",
  "title": "KAVEEP Audit Event",
  "description": "Canonical audit event schema for traceability across KAVEEP entities, KCP sessions, evidence, policy checks, agents, and verification results.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "auditId",
    "eventType",
    "timestamp",
    "actor",
    "target",
    "action",
    "result",
    "riskLevel",
    "createdAt"
  ],
  "properties": {
    "auditId": {
      "type": "string",
      "pattern": "^audit_[a-zA-Z0-9_-]+$",
      "description": "Stable unique identifier for this audit event."
    },
    "eventType": {
      "type": "string",
      "enum": [
        "knowledge_created",
        "knowledge_updated",
        "knowledge_deprecated",
        "evidence_attached",
        "evidence_removed",
        "agent_evaluation_started",
        "agent_evaluation_completed",
        "policy_check_started",
        "policy_check_completed",
        "kcp_session_started",
        "kcp_session_completed",
        "truth_result_issued",
        "approval_requested",
        "approval_granted",
        "approval_denied",
        "system_warning",
        "simulation_executed",
        "execution_blocked",
        "schema_created",
        "schema_updated",
        "example_created",
        "example_updated"
      ]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "actor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "actorId",
        "actorType"
      ],
      "properties": {
        "actorId": {
          "type": "string"
        },
        "actorType": {
          "type": "string",
          "enum": [
            "human",
            "agent",
            "system",
            "policy_engine",
            "kcp_engine",
            "audit_engine",
            "schema_engine"
          ]
        },
        "actorName": {
          "type": "string"
        }
      }
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "targetId",
        "targetType"
      ],
      "properties": {
        "targetId": {
          "type": "string"
        },
        "targetType": {
          "type": "string",
          "enum": [
            "knowledge",
            "evidence",
            "agent",
            "policy",
            "kcp_session",
            "truth_claim",
            "system_resource",
            "file",
            "report",
            "schema",
            "example",
            "repository"
          ]
        }
      }
    },
    "action": {
      "type": "string",
      "description": "Human-readable description of the action performed."
    },
    "result": {
      "type": "string",
      "enum": [
        "success",
        "failed",
        "blocked",
        "pending",
        "requires_approval",
        "unverified"
      ]
    },
  "riskLevel": {
  "type": "string",
  "enum": [
    "low",
    "moderate",
    "high",
    "critical"
  ]
},
    "policyRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^policy_[a-zA-Z0-9_-]+$"
      },
      "uniqueItems": true
    },
    "evidenceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^evidence_[a-zA-Z0-9_-]+$"
      },
      "uniqueItems": true
    },
    "knowledgeRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^knowledge_[a-zA-Z0-9_-]+$"
      },
      "uniqueItems": true
    },
    "agentRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^agent_[a-zA-Z0-9_-]+$"
      },
      "uniqueItems": true
    },
    "kcpSessionRef": {
      "type": "string",
      "pattern": "^kcp_[a-zA-Z0-9_-]+$"
    },
    "previousAuditRef": {
      "type": "string",
      "pattern": "^audit_[a-zA-Z0-9_-]+$"
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "verificationStatus": {
          "type": "string",
          "enum": [
            "verified",
            "unverified",
            "rejected",
            "deprecated",
            "superseded"
          ]
        },
        "verificationLevel": {
          "type": "string",
          "enum": [
            "unverified",
            "preliminary",
            "reviewed",
            "verified",
            "certified",
            "foundational"
          ]
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "consensusScore": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "evidenceCount": {
          "type": "integer",
          "minimum": 0
        },
        "independentAgentCount": {
          "type": "integer",
          "minimum": 0
        },
        "policyPassed": {
          "type": "boolean"
        }
      }
    },
    "notes": {
      "type": "string"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
