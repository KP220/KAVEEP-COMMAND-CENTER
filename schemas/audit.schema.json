{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kaveep.dev/schemas/audit.schema.json",
  "title": "KAVEEP Audit Event",
  "description": "Canonical audit event schema for immutable traceability across all KAVEEP entities, policies, agents, KCP sessions, evidence, events, approvals, and system operations.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "auditId",
    "eventType",
    "timestamp",
    "actor",
    "target",
    "action",
    "result",
    "riskLevel",
    "createdAt"
  ],
  "properties": {
    "auditId": {
      "type": "string",
      "pattern": "^audit_[a-zA-Z0-9_-]+$"
    },
    "eventType": {
      "type": "string",
      "enum": [
        "mission_created",
        "mission_updated",
        "workflow_created",
        "workflow_updated",
        "task_created",
        "task_updated",
        "task_completed",
        "agent_registered",
        "agent_updated",
        "policy_check_started",
        "policy_check_completed",
        "security_check_started",
        "security_check_completed",
        "kcp_session_started",
        "kcp_session_completed",
        "knowledge_created",
        "knowledge_updated",
        "knowledge_deprecated",
        "evidence_attached",
        "evidence_removed",
        "truth_result_issued",
        "approval_requested",
        "approval_granted",
        "approval_denied",
        "event_published",
        "plugin_installed",
        "plugin_updated",
        "api_call_executed",
        "system_warning",
        "simulation_executed",
        "execution_blocked",
        "schema_created",
        "schema_updated",
        "example_created",
        "example_updated"
      ]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "actor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "actorId",
        "actorType"
      ],
      "properties": {
        "actorId": {
          "type": "string"
        },
        "actorType": {
          "type": "string",
          "enum": [
            "human",
            "user",
            "agent",
            "system",
            "policy_engine",
            "security_engine",
            "kcp_engine",
            "audit_engine",
            "schema_engine",
            "plugin_engine",
            "api_gateway"
          ]
        },
        "actorName": {
          "type": "string"
        }
      }
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "targetId",
        "targetType"
      ],
      "properties": {
        "targetId": {
          "type": "string"
        },
        "targetType": {
          "type": "string",
          "enum": [
            "mission",
            "goal",
            "workflow",
            "task",
            "agent",
            "capability",
            "passport",
            "identity",
            "user",
            "approval",
            "policy",
            "policy_check",
            "security_check",
            "knowledge",
            "evidence",
            "kcp_session",
            "truth_claim",
            "audit",
            "event",
            "plugin",
            "api_call",
            "system_resource",
            "file",
            "report",
            "schema",
            "example",
            "repository"
          ]
        }
      }
    },
    "action": {
      "type": "string",
      "minLength": 1
    },
    "result": {
      "type": "string",
      "enum": [
        "success",
        "failed",
        "blocked",
        "pending",
        "requires_approval",
        "unverified"
      ]
    },
    "riskLevel": {
      "type": "string",
      "enum": [
        "low",
        "moderate",
        "high",
        "critical"
      ]
    },
    "policyRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^policy_[a-zA-Z0-9_-]+$"
      },
      "uniqueItems": true
    },
    "evidenceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^evidence_[a-zA-Z0-9_-]+$"
      },
      "uniqueItems": true
    },
    "knowledgeRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^knowledge_[a-zA-Z0-9_-]+$"
      },
      "uniqueItems": true
    },
    "agentRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^agent_[a-zA-Z0-9_-]+$"
      },
      "uniqueItems": true
    },
    "eventRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^event_[a-zA-Z0-9_-]+$"
      },
      "uniqueItems": true
    },
    "kcpSessionRef": {
      "type": "string",
      "pattern": "^kcp_[a-zA-Z0-9_-]+$"
    },
    "previousAuditRef": {
      "type": "string",
      "pattern": "^audit_[a-zA-Z0-9_-]+$"
    },
    "correlationId": {
      "type": "string",
      "description": "Shared correlation identifier connecting mission, workflow, task, event, audit, or KCP chains."
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "verificationStatus": {
          "type": "string",
          "enum": [
            "verified",
            "unverified",
            "rejected",
            "deprecated",
            "superseded"
          ]
        },
        "verificationLevel": {
          "type": "string",
          "enum": [
            "unverified",
            "preliminary",
            "reviewed",
            "verified",
            "certified",
            "foundational"
          ]
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "consensusScore": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "evidenceCount": {
          "type": "integer",
          "minimum": 0
        },
        "independentAgentCount": {
          "type": "integer",
          "minimum": 0
        },
        "policyPassed": {
          "type": "boolean"
        }
      }
    },
    "notes": {
      "type": "string"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
