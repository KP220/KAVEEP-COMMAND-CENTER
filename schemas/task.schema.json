{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kaveep.dev/schemas/task.schema.json",
  "title": "KAVEEP Task",
  "description": "Canonical schema for the smallest managed unit of operational execution in KAVEEP.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "taskId",
    "name",
    "taskType",
    "status",
    "priority",
    "riskLevel",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "taskId": {
      "type": "string",
      "pattern": "^task_[a-zA-Z0-9_-]+$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "taskType": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "created",
        "queued",
        "scheduled",
        "waiting_dependency",
        "waiting_approval",
        "waiting_kcp",
        "running",
        "paused",
        "retrying",
        "completed",
        "cancelled",
        "failed",
        "archived"
      ]
    },
    "priority": {
      "type": "string",
      "enum": [
        "emergency",
        "critical",
        "high",
        "normal",
        "low",
        "background"
      ]
    },
    "riskLevel": {
      "type": "string",
      "enum": [
        "low",
        "moderate",
        "high",
        "critical"
      ]
    },
    "missionId": {
      "type": "string",
      "pattern": "^mission_[a-zA-Z0-9_-]+$"
    },
    "workflowId": {
      "type": "string",
      "pattern": "^workflow_[a-zA-Z0-9_-]+$"
    },
    "goalId": {
      "type": "string",
      "pattern": "^goal_[a-zA-Z0-9_-]+$"
    },
    "ownerAgentId": {
      "type": "string",
      "pattern": "^agent_[a-zA-Z0-9_-]+$"
    },
    "assignedAgentId": {
      "type": "string",
      "pattern": "^agent_[a-zA-Z0-9_-]+$"
    },
    "requiredCapabilityId": {
      "type": "string",
      "pattern": "^capability_[a-zA-Z0-9_-]+$"
    },
    "policyProfile": {
      "type": "string"
    },
    "approvalId": {
      "type": "string",
      "pattern": "^approval_[a-zA-Z0-9_-]+$"
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^task_[a-zA-Z0-9_-]+$"
      },
      "uniqueItems": true
    },
    "estimatedDurationSeconds": {
      "type": "integer",
      "minimum": 0
    },
    "actualDurationSeconds": {
      "type": "integer",
      "minimum": 0
    },
    "retryCount": {
      "type": "integer",
      "minimum": 0
    },
    "maxRetries": {
      "type": "integer",
      "minimum": 0
    },
    "scheduledAt": {
      "type": "string",
      "format": "date-time"
    },
    "startedAt": {
      "type": "string",
      "format": "date-time"
    },
    "finishedAt": {
      "type": "string",
      "format": "date-time"
    },
    "result": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "success",
            "partial",
            "failed",
            "cancelled",
            "unverified"
          ]
        },
        "summary": {
          "type": "string"
        },
        "outputRef": {
          "type": "string"
        }
      }
    },
    "auditRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^audit_[a-zA-Z0-9_-]+$"
      },
      "uniqueItems": true
    },
    "eventRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^event_[a-zA-Z0-9_-]+$"
      },
      "uniqueItems": true
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
