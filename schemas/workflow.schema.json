{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kaveep.dev/schemas/workflow.schema.json",
  "title": "KAVEEP Workflow",
  "description": "Canonical schema for a coordinated sequence of tasks within KAVEEP.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "workflowId",
    "name",
    "status",
    "priority",
    "riskLevel",
    "tasks",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "workflowId": {
      "type": "string",
      "pattern": "^workflow_[a-zA-Z0-9_-]+$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "missionId": {
      "type": "string",
      "pattern": "^mission_[a-zA-Z0-9_-]+$"
    },
    "goalId": {
      "type": "string",
      "pattern": "^goal_[a-zA-Z0-9_-]+$"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "validated",
        "approved",
        "queued",
        "running",
        "paused",
        "waiting_approval",
        "waiting_dependency",
        "completed",
        "failed",
        "cancelled",
        "archived"
      ]
    },
    "priority": {
      "type": "string",
      "enum": [
        "emergency",
        "critical",
        "high",
        "normal",
        "low",
        "background"
      ]
    },
    "riskLevel": {
      "type": "string",
      "enum": [
        "low",
        "moderate",
        "high",
        "critical"
      ]
    },
    "workflowType": {
      "type": "string"
    },
    "blueprintId": {
      "type": "string"
    },
    "ownerAgentId": {
      "type": "string",
      "pattern": "^agent_[a-zA-Z0-9_-]+$"
    },
    "assignedAgentIds": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^agent_[a-zA-Z0-9_-]+$"
      },
      "uniqueItems": true
    },
    "requiredCapabilities": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^capability_[a-zA-Z0-9_-]+$"
      },
      "uniqueItems": true
    },
    "requiredPolicies": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^policy_[a-zA-Z0-9_-]+$"
      },
      "uniqueItems": true
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^task_[a-zA-Z0-9_-]+$"
      },
      "uniqueItems": true
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^workflow_[a-zA-Z0-9_-]+$"
      },
      "uniqueItems": true
    },
    "approvalIds": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^approval_[a-zA-Z0-9_-]+$"
      },
      "uniqueItems": true
    },
    "recoveryStrategy": {
      "type": "string",
      "enum": [
        "none",
        "retry",
        "rollback",
        "pause",
        "manual_recovery",
        "fallback_workflow",
        "safe_stop"
      ]
    },
    "startedAt": {
      "type": "string",
      "format": "date-time"
    },
    "finishedAt": {
      "type": "string",
      "format": "date-time"
    },
    "auditRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^audit_[a-zA-Z0-9_-]+$"
      },
      "uniqueItems": true
    },
    "eventRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^event_[a-zA-Z0-9_-]+$"
      },
      "uniqueItems": true
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
