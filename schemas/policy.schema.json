{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kaveep.dev/schemas/policy.schema.json",
  "title": "KAVEEP Policy",
  "description": "Canonical schema for governance policies within the KAVEEP ecosystem.",
  "type": "object",
  "additionalProperties": false,

  "required": [
    "policyId",
    "name",
    "version",
    "status",
    "scope",
    "rules",
    "createdAt",
    "updatedAt"
  ],

  "properties": {

    "policyId": {
      "type": "string",
      "pattern": "^policy_[a-zA-Z0-9_-]+$"
    },

    "name": {
      "type": "string",
      "minLength": 1
    },

    "description": {
      "type": "string"
    },

    "version": {
      "type": "string"
    },

    "status": {
      "type": "string",
      "enum": [
        "draft",
        "review",
        "approved",
        "active",
        "deprecated",
        "archived"
      ]
    },

    "scope": {
      "type": "string",
      "enum": [
        "global",
        "organization",
        "platform",
        "module",
        "plugin",
        "workflow",
        "task",
        "agent"
      ]
    },

    "priority": {
      "type": "integer",
      "minimum": 0
    },

    "riskLevel": {
      "type": "string",
      "enum": [
        "low",
        "moderate",
        "high",
        "critical"
      ]
    },

    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {

        "type": "object",

        "required": [
          "ruleId",
          "effect",
          "condition"
        ],

        "properties": {

          "ruleId": {
            "type": "string"
          },

          "description": {
            "type": "string"
          },

          "effect": {
            "type": "string",
            "enum": [
              "allow",
              "deny",
              "requireApproval",
              "requireKCP",
              "warn"
            ]
          },

          "condition": {
            "type": "string"
          },

          "reason": {
            "type": "string"
          }

        }

      }
    },

    "appliesTo": {

      "type": "array",

      "items": {
        "type": "string"
      }

    },

    "requiredApprovals": {

      "type": "array",

      "items": {
        "type": "string",
        "pattern": "^approval_[a-zA-Z0-9_-]+$"
      }

    },

    "requiredCapabilities": {

      "type": "array",

      "items": {
        "type": "string",
        "pattern": "^capability_[a-zA-Z0-9_-]+$"
      }

    },

    "relatedKnowledge": {

      "type": "array",

      "items": {
        "type": "string",
        "pattern": "^knowledge_[a-zA-Z0-9_-]+$"
      }

    },

    "kcpRequired": {
      "type": "boolean"
    },

    "simulationSupported": {
      "type": "boolean"
    },

    "rollbackSupported": {
      "type": "boolean"
    },

    "auditRefs": {

      "type": "array",

      "items": {
        "type": "string",
        "pattern": "^audit_[a-zA-Z0-9_-]+$"
      }

    },

    "createdBy": {
      "type": "string"
    },

    "approvedBy": {
      "type": "string"
    },

    "effectiveFrom": {
      "type": "string",
      "format": "date-time"
    },

    "effectiveUntil": {
      "type": "string",
      "format": "date-time"
    },

    "createdAt": {
      "type": "string",
      "format": "date-time"
    },

    "updatedAt": {
      "type": "string",
      "format": "date-time"
    }

  }

}
